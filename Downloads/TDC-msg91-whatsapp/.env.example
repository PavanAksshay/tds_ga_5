# TDC Environment Variables
# ⚠️  NEVER commit .env to git — it is in .gitignore
# Copy this file to .env and fill in your values for local development.
#
# For PRODUCTION (Cloudflare Workers), set these as secrets via:
#   wrangler secret put SUPABASE_PROJECT_URL
#   wrangler secret put SUPABASE_ANON_KEY
#   wrangler secret put SUPABASE_API_KEY
#   wrangler secret put SUPABASE_SERVICE_ROLE_KEY
#   wrangler secret put GOOGLE_CLIENT_ID
#   wrangler secret put GOOGLE_CLIENT_SECRET
#   wrangler secret put GMAIL_USER          # optional — for admin PIN reset emails
#   wrangler secret put GMAIL_APP_PASS      # optional — for admin PIN reset emails
#
# Or set them in Cloudflare Dashboard → Workers & Pages → tdc-app → Settings → Variables

SUPABASE_PROJECT_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_API_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Optional: for admin PIN reset email functionality
GMAIL_USER="your-gmail@gmail.com"
GMAIL_APP_PASS="your-gmail-app-password"

# ── MSG91 WhatsApp OTP ─────────────────────────────────────
# Sends phone-verification OTPs over WhatsApp via MSG91.
# Get these from your MSG91 dashboard: https://msg91.com/
# (If left blank, OTP calls are logged to the server console and
#  any 6-digit code is accepted — useful for local dev.)
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_TEMPLATE_ID="your-whatsapp-template-id"
# Optional tuning:
MSG91_OTP_LENGTH="6"
MSG91_OTP_EXPIRY="10"

# ── MSG91 Email OTP ────────────────────────────────────────
# Sends email-verification OTPs via MSG91's Email API.
# NOTE: MSG91 email only DELIVERS the message — the OTP is generated and
# verified by this app (stored in the email_otps table). The MSG91 email
# template should reference the code via the {{otp}} handlebars variable
# (and optionally {{expiry}} for the validity window in minutes).
# Reuses MSG91_AUTH_KEY above. Configure a verified sending domain in MSG91.
# (If any of these are left blank, the OTP email is logged to the server
#  console instead of being sent — useful for local dev.)
MSG91_EMAIL_DOMAIN="mail.yourdomain.com"
MSG91_EMAIL_FROM="no-reply@mail.yourdomain.com"
MSG91_EMAIL_TEMPLATE_ID="your-email-template-id"
# Optional:
MSG91_EMAIL_FROM_NAME="The Developer Community"
