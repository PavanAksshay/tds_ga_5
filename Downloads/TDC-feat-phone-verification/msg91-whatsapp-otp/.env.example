# MSG91 WhatsApp OTP Configuration
# Get these from your MSG91 dashboard: https://msg91.com/

# Required: Your MSG91 auth key
MSG91_AUTH_KEY=

# Required: Template ID configured for WhatsApp delivery in MSG91 dashboard
MSG91_TEMPLATE_ID=

# Optional: OTP digit count (default: 6)
MSG91_OTP_LENGTH=6

# Optional: OTP expiry in minutes (default: 10)
MSG91_OTP_EXPIRY=10
